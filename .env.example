# App Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

## Database
DATABASE_URL=postgresql://user:pass@localhost:5432/ai_generator?pgbouncer=true
DIRECT_URL=postgresql://user:pass@localhost:5432/ai_generator
DATABASE_SSL=false

# JWT
JWT_ACCESS_SECRET=your-access-secret
JWT_REFRESH_SECRET=your-refresh-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id-from-console
GOOGLE_CLIENT_SECRET=your-google-client-secret-from-console
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# S3/R2 (Cloudflare R2 é compatível com S3)
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=ai-generations
S3_PUBLIC_URL=https://cdn.geraew.com.br/storage/v1/object/public/ai-generations # CDN URL para servir arquivos

# Geraew Provider (servico externo que faz todas as geracoes de IA)
GERAEW_PROVIDER_URL=http://localhost:3001
GERAEW_API_KEY=

# Pagamentos
STRIPE_SECRET_KEY=           # sk_test_... (dev) ou sk_live_... (prod)
STRIPE_WEBHOOK_SECRET=       # whsec_... do Stripe Dashboard
STRIPE_SUCCESS_URL=http://localhost:5173/payment/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:5173/payment/cancel

# Stripe Price IDs (v5 pricing — ,90)
STRIPE_PRICE_PLAN_STARTER=   # live: price_1TFgcaBFQnG9Nke5RUqrwaMR (R$39,90/mês)
STRIPE_PRICE_PLAN_CREATOR=   # live: price_1TFgcbBFQnG9Nke5b4QqLHwU (R$89,90/mês)
STRIPE_PRICE_PLAN_PRO=       # live: price_1TFgccBFQnG9Nke5c5GC5onO (R$179,90/mês)
STRIPE_PRICE_PLAN_STUDIO=    # live: price_1TFgcdBFQnG9Nke5iKG0gMWe (R$369,90/mês)
STRIPE_PRICE_BOOST_P=        # live: price_1TFgceBFQnG9Nke5CvuZNGEV (R$14,90)
STRIPE_PRICE_BOOST_M=        # live: price_1TFgcfBFQnG9Nke5RBKX91I4 (R$26,90)
STRIPE_PRICE_BOOST_G=        # live: price_1TFgcgBFQnG9Nke5IhiNaGPw (R$36,90)

MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# ASAAS (PIX para boost — cobrança única; quando ligar PIX Automático para
# assinaturas, reusar a mesma API key)
# Sandbox: https://api-sandbox.asaas.com  |  Produção: https://api.asaas.com
ASAAS_API_KEY=               # $aact_... (gerado no painel do ASAAS)
ASAAS_BASE_URL=https://api-sandbox.asaas.com
ASAAS_WEBHOOK_SECRET=        # token livre — configurar igual no webhook do painel ASAAS

# Hotmart (webhook de compra de curso → pending grant de free generations)
HOTMART_HOTTOK=             # token configurado no painel da Hotmart

# Greenn (webhook de compra de curso → pending grant de free generations)
GREENN_WEBHOOK_TOKEN=       # token compartilhado: enviado via ?token= ou header x-greenn-token

# Cartpanda (webhook de compra → pending grant de free generations)
CARTPANDA_WEBHOOK_TOKEN=    # token compartilhado: enviado via ?token= ou header x-cartpanda-token

# Redis (BullMQ + Pub/Sub)
REDIS_URL=redis://default:password@localhost:6379

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# Firebase (Phone Auth — verificação de SMS no cadastro)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxx
RESEND_FROM_EMAIL=Geraew <noreply@geraew.ai>
FRONTEND_URL=http://localhost:5173

# Watermark
WATERMARK_IMAGE_PATH=assets/watermark.png

# Replicate (Seedream 4.5)
REPLICATE_API_TOKEN=

# HeyGen (clonagem de avatar — Digital Twin v3)
HEYGEN_API_KEY=
HEYGEN_BASE_URL=https://api.heygen.com
HEYGEN_WEBHOOK_SECRET=
# {avatarId} é substituído em runtime pelo backend ao montar a URL final
HEYGEN_CONSENT_REROUTE_URL=http://localhost:3000/workspace/avatars/{avatarId}?consent=done
AVATAR_TRAINING_CREDITS_PHOTO=1250
AVATAR_TRAINING_CREDITS_DIGITAL_TWIN=2000
AVATAR_TRAINING_TIMEOUT_MIN=90
